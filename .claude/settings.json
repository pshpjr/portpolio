{
  "enabledPlugins": {
    "context-engineering@context-engineering-marketplace": true,
    "codex@openai-codex": true
  },
  "project": {
    "name": "portpolio",
    "entrypoint": "AGENTS.md",
    "planIndex": "docs/exec-plans/active/INDEX.md"
  },
  "harness": {
    "enabled": true,
    "defaultAgents": [
      "worker",
      "reviewer",
      "scaffolder"
    ],
    "memoryRoot": ".claude/agent-memory"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/token_logger.py 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
