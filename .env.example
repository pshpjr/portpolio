# =============================================================================
# Runtime — required (server will not start without these)
# =============================================================================
PORT=8080
DB_HOST=localhost
DB_USER=portpolio
DB_PASSWORD=changeme
REDIS_URL=redis://localhost:6379

# =============================================================================
# Runtime — optional (fall back to server.json or built-in defaults)
# =============================================================================
# SERVER_NAME=portpolio
# SHARD_ID=1
# SERVICE_ENDPOINT=https://api.example.com
# FEATURE_FLAGS=dungeon_v2,party_hud
# LOG_LEVEL=info          # trace | debug | info | warn | error | critical

# =============================================================================
# Codegen paths — optional (CI/CD: set as pipeline env vars instead)
# =============================================================================
# PORTPOLIO_SERVER_OUT=server/src/generated
# PORTPOLIO_UNREAL_OUT=client/Source/client/Public/Generated
# PROTOC_PATH=/usr/local/bin/protoc
